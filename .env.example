BAIRUI_PRODUCT_NAME=bairui Agent OS
BAIRUI_BRAND_KEY=bairui
BAIRUI_TRADEMARK_NAME=bairui
BAIRUI_LOGO_TEXT=bairui
HERMES_ENV=development

# PostgreSQL skeleton environment.
POSTGRES_DB=moxi
POSTGRES_USER=moxi
POSTGRES_PASSWORD=
POSTGRES_PORT=5432
HERMES_DATABASE_URL=

# Local paths. Real runtime data must stay outside Git.
HERMES_DATA_DIR=./data/hermes
HERMES_LOG_DIR=./logs/hermes
HERMES_OBSIDIAN_VAULT_DIR=./obsidian-vault

# Commercial platform integration placeholders.
MOXI_PLATFORM_BASE_URL=
MOXI_SERVER_ID=
MOXI_LICENSE_FILE=./license/moxi-license.json
BAIRUI_LICENSE_SECRET=

# OpenAI-compatible model gateway. Never commit real keys.
BAIRUI_MODEL_BASE_URL=
BAIRUI_MODEL_API_KEY=
BAIRUI_MODEL_NAME=
BAIRUI_MODEL_TIMEOUT_SECONDS=60

# Vendor runtime adapters. Empty values must report missing_config honestly.
EVEROS_BASE_URL=
EVEROS_MEMORY_ROOT=./data/everos
EVEROS_TIMEOUT_SECONDS=30
TRENDRADAR_PROJECT_ROOT=
TRENDRADAR_MCP_URL=
TRENDRADAR_TIMEOUT_SECONDS=30
MIROFISH_PROJECT_ROOT=
MIROFISH_BACKEND_BASE_URL=
MIROFISH_FRONTEND_BASE_URL=
MIROFISH_TIMEOUT_SECONDS=30
SEARXNG_BASE_URL=
SEARXNG_PUBLIC_BASE_URL=
SEARXNG_TIMEOUT_SECONDS=30
SONIC_HOST=
SONIC_PORT=1491
SONIC_PASSWORD=
SONIC_TIMEOUT_SECONDS=10
FUNASR_PROJECT_ROOT=
FUNASR_BASE_URL=
FUNASR_PUBLIC_BASE_URL=
FUNASR_MODEL=fun-asr-nano
FUNASR_TIMEOUT_SECONDS=120
MINERU_PROJECT_ROOT=
MINERU_OUTPUT_DIR=./data/mineru-output
MINERU_BACKEND=pipeline
MINERU_DEVICE=cpu
MINERU_TIMEOUT_SECONDS=600

# Connector and tool secrets will be reintroduced only when rebuilt source needs
# them. Never commit real secrets to this file.
