HERMES_APP_NAME=hermes-runtime
HERMES_ENV=production
HERMES_HOST=127.0.0.1
HERMES_PORT=8787
HERMES_SAFE_MODE=true
HERMES_DATA_DIR=/opt/hermes-system/data
HERMES_LOG_DIR=/opt/hermes-system/logs
HERMES_OBSIDIAN_VAULT_DIR=/opt/hermes-system/obsidian-vault
HERMES_ENABLE_FEISHU_SMOKE=false
HERMES_SEARCH_MODE=external_project
HERMES_SEARCH_PROJECT=trendradar
HERMES_TRENDRADAR_BASE_URL=
HERMES_TRENDRADAR_MCP_COMMAND=
HERMES_SEARXNG_BASE_URL=
HERMES_AI_PROVIDER=supermoxi
HERMES_AI_BASE_URL=https://api.supermoxi.cn
HERMES_AI_DEFAULT_MODEL=
HERMES_AI_FAST_MODEL=
HERMES_AI_REASONING_MODEL=
HERMES_AI_VISION_MODEL=
HERMES_AI_TIMEOUT_SECONDS=60
HERMES_WECHAT_MODE=disabled
HERMES_WECHAT_CHANNEL=official_account
HERMES_WECHAT_PERSONA_MODE=companion
HERMES_WECHAT_PROACTIVE_CHAT=false
HERMES_WECHAT_MAX_DAILY_PROACTIVE_MESSAGES=3
HERMES_WECHAT_PERSONAL_BRIDGE_ENABLED=false
HERMES_STICKER_BRIDGE_ENABLED=false
HERMES_STICKER_DEFAULT_PROVIDER=metadata_only
HERMES_STICKER_DEFAULT_STYLE=kawaii_anime
HERMES_STICKER_IMAGE_GENERATION_ENABLED=false
HERMES_STICKER_IMAGE_GENERATION_MODEL=
HERMES_STICKER_GENERATION_REVIEW_REQUIRED=true
HERMES_STICKER_RUNTIME_CACHE_ENABLED=false

# Keep real secrets only in the server-side .env file. Never commit them.
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_WEBHOOK_URL=
HERMES_AI_API_KEY=
HERMES_WECHAT_OFFICIAL_APP_ID=
HERMES_WECHAT_OFFICIAL_APP_SECRET=
HERMES_WECHAT_OFFICIAL_TOKEN=
HERMES_WECHAT_OFFICIAL_AES_KEY=
HERMES_WECOM_CORP_ID=
HERMES_WECOM_AGENT_ID=
HERMES_WECOM_SECRET=
HERMES_WECOM_CUSTOMER_SERVICE_TOKEN=
HERMES_STICKER_API_KEY=
