# Copy this file to a protected server path such as /etc/bairui/hermes.env.
# Do not commit real production values.

BAIRUI_PRODUCT_NAME=bairui Agent OS
BAIRUI_BRAND_KEY=bairui
BAIRUI_TRADEMARK_NAME=bairui
BAIRUI_LOGO_TEXT=bairui
HERMES_ENV=production
HERMES_HOST=127.0.0.1
HERMES_PORT=8787

POSTGRES_DB=moxi
POSTGRES_USER=moxi
POSTGRES_PASSWORD=change-me-long-random-password
POSTGRES_PORT=5432
HERMES_DATABASE_URL=postgresql://moxi:change-me-long-random-password@127.0.0.1:5432/moxi

HERMES_DATA_DIR=/var/lib/bairui/hermes/data
HERMES_LOG_DIR=/var/log/bairui/hermes
HERMES_OBSIDIAN_VAULT_DIR=/var/lib/bairui/hermes/obsidian-vault
EVEROS_BASE_URL=http://127.0.0.1:8000
EVEROS_MEMORY_ROOT=/var/lib/bairui/hermes/everos
EVEROS_TIMEOUT_SECONDS=30
TRENDRADAR_PROJECT_ROOT=/opt/bairui/vendor/runtimes/trendradar
TRENDRADAR_MCP_URL=http://127.0.0.1:3333/mcp
TRENDRADAR_TIMEOUT_SECONDS=30
MIROFISH_PROJECT_ROOT=/opt/bairui/vendor/runtimes/mirofish
MIROFISH_BACKEND_BASE_URL=http://127.0.0.1:5001
MIROFISH_FRONTEND_BASE_URL=http://127.0.0.1:5173
MIROFISH_TIMEOUT_SECONDS=30
SEARXNG_BASE_URL=http://127.0.0.1:8080
SEARXNG_PUBLIC_BASE_URL=http://127.0.0.1:8080
SEARXNG_TIMEOUT_SECONDS=30

MOXI_PLATFORM_BASE_URL=https://platform.example.com
MOXI_SERVER_ID=srv_change_me
MOXI_LICENSE_FILE=/etc/bairui/hermes-license.json
BAIRUI_LICENSE_SECRET=change-me-long-random-license-secret

BAIRUI_MODEL_BASE_URL=
BAIRUI_MODEL_API_KEY=
BAIRUI_MODEL_NAME=
BAIRUI_MODEL_TIMEOUT_SECONDS=60
