diff --git a/src/ui/brain-ui/api-client.js b/src/ui/brain-ui/api-client.js
--- a/src/ui/brain-ui/api-client.js
+++ b/src/ui/brain-ui/api-client.js
@@
+export const API = (() => {
+  const configured = String(globalThis.__BRAIN_API_BASE__ || '').trim();
+  if (configured && !/^https?:\/\/(127\.0\.0\.1|localhost)(:\d+)?/i.test(configured)) {
+    return configured.replace(/\/+$/, '');
+  }
+  // Browser code must use same-origin paths. 127.0.0.1 would point at the
+  // user's computer, not the VPS that serves Brain UI.
+  return '';
+})();
+
+export function apiUrl(path) {
+  const p = String(path || '');
+  return `${API}${p.startsWith('/') ? p : `/${p}`}`;
+}

diff --git a/etc/nginx/conf.d/bairui-chat.conf b/etc/nginx/conf.d/bairui-chat.conf
