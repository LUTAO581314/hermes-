+++ b/etc/nginx/conf.d/bairui-chat.conf
@@
+location = /events {
+  proxy_pass http://127.0.0.1:3721/events;
+  proxy_http_version 1.1;
+  proxy_set_header Connection '';
+  proxy_buffering off;
+  proxy_cache off;
+  proxy_read_timeout 1h;
+  add_header X-Accel-Buffering no;
+}
