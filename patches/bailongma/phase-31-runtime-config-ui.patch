diff --git a/src/ui/brain-ui/styles.css b/src/ui/brain-ui/styles.css
--- a/src/ui/brain-ui/styles.css
+++ b/src/ui/brain-ui/styles.css
@@
+/* Phase 31 Hermes schema-driven runtime settings */
+.settings-schema-status { margin-bottom: 12px; color: var(--ink2); font-size: 11px; font-family: "JetBrains Mono", ui-monospace, monospace; }
+.settings-schema-grid { display: grid; gap: 14px; }
+.settings-schema-group { border: 1px solid var(--line); border-radius: 6px; overflow: hidden; background: rgba(255,255,255,0.018); }
+.settings-schema-fields { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; padding: 12px; }
+.settings-schema-field { min-width: 0; padding: 10px; border: 1px solid var(--line); border-radius: 6px; background: rgba(0,0,0,0.08); }
+.settings-schema-pill.ready { border-color: rgba(114,207,161,0.45); color: var(--cool); }
+.settings-schema-pill.missing { border-color: rgba(220,104,90,0.48); color: var(--warm); }
