diff --git a/src/api.js b/src/api.js
--- a/src/api.js
+++ b/src/api.js
@@
+    // GET /config/schema - proxy Hermes writable config schema through BaiLongma
+    if (req.method === 'GET' && url.pathname === '/config/schema') {
+      const schema = await fetchHermesReadOnly('/config/schema')
+      if (!schema.connected) {
+        jsonResponse(res, 503, { ok: false, error: 'hermes_config_schema_unavailable', reason: schema.reason || 'unknown' })
+        return
+      }
+      jsonResponse(res, 200, { ok: true, source: 'bailongma-hermes-bridge', ...(schema.payload || {}) })
+      return
+    }
+
+    // POST /config/update - save whitelisted Hermes runtime config values
+    if (req.method === 'POST' && url.pathname === '/config/update') {
+      if (!requireLocalOrToken(req, res, url)) return
+      const chunks = []
+      req.on('data', chunk => chunks.push(chunk))
+      req.on('end', async () => {
+        try {
+          const body = JSON.parse(Buffer.concat(chunks).toString('utf-8') || '{}')
+          const result = await postHermesRuntimeJson('/config/update', body, { timeoutMs: 5000 })
+          if (!result.ok) {
+            jsonResponse(res, 502, { ok: false, error: 'hermes_config_update_failed', reason: result.reason || 'unknown' })
+            return
+          }
+          jsonResponse(res, 200, { ok: true, source: 'bailongma-hermes-bridge', ...(result.payload || {}) })
+        } catch (err) {
+          jsonResponse(res, 400, { ok: false, error: err.message })
+        }
+      })
+      return
+    }
