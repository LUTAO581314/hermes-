[Unit]
Description=Hermes Runtime
After=network.target

[Service]
Type=simple
User=hermes
Group=hermes
WorkingDirectory=/opt/hermes-system
EnvironmentFile=/opt/hermes-system/.env
ExecStart=/usr/bin/python3 -m hermes_runtime
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ReadWritePaths=/opt/hermes-system/data /opt/hermes-system/logs /opt/hermes-system/obsidian-vault /opt/hermes-system/backups

[Install]
WantedBy=multi-user.target
